    <style>
        /* CSS styles for premium look */
        .bg-light-soft {
            background-color: rgba(248, 249, 250, 0.7);
        }

        .bg-soft-primary {
            background-color: rgba(67, 107, 230, 0.1);
        }

        .bg-soft-success {
            background-color: rgba(30, 196, 128, 0.1);
        }

        .bg-soft-info {
            background-color: rgba(30, 158, 196, 0.1);
        }

        .bg-soft-secondary {
            background-color: rgba(108, 117, 125, 0.1);
        }

        .bg-soft-warning-gradient {
            background: linear-gradient(135deg, rgba(255, 193, 7, 0.05) 0%, rgba(255, 255, 255, 1) 100%);
        }

        .header-icon-box {
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            font-size: 1.2rem;
        }

        .premium-card-glass {
            background-color: rgba(255, 255, 255, 0.95);
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .premium-card-glass:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08) !important;
        }

        .description-box {
            line-height: 1.6;
            font-size: 0.95rem;
            background-color: #f9f9fb;
        }

        .info-item-box {
            transition: all 0.2s;
        }

        .info-item-box:hover {
            background-color: #fff !important;
            border-color: #4A89DC !important;
        }

        .custom-premium-table thead th {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6c757d;
            padding: 15px;
        }

        .custom-premium-table tbody td {
            padding: 15px;
            vertical-align: middle;
        }

        .table-highlight-active {
            background-color: rgba(30, 196, 128, 0.03);
        }

        .shadow-sm-icon {
            filter: drop-shadow(0 2px 4px rgba(30, 196, 128, 0.2));
        }

        .premium-service-tag {
            background-color: #fff;
            font-size: 0.85rem;
            transition: 0.3s;
        }

        .premium-service-tag:hover {
            border-color: #309ec4 !important;
            background-color: rgba(30, 158, 196, 0.02);
        }

        .service-orb {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }

        .border-start-thick-success {
            border-left: 4px solid #1ec480 !important;
        }

        .border-start-thick-danger {
            border-left: 4px solid #f44336 !important;
        }

        .custom-success-list span,
        .custom-danger-list span {
            font-size: 0.9rem;
            color: #333;
        }

        .border-dashed-warning {
            border: 1px dashed rgba(255, 193, 7, 0.3);
        }

        .aspect-ratio-box-4-3 {
            width: 100%;
            padding-top: 75%;
            /* 4:3 aspect ratio */
            position: relative;
            overflow: hidden;
        }

        .carousel-image-fit {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .img-thumbnail-fit {
            height: 60px;
            object-fit: cover;
        }

        .bg-success-gradient {
            background: linear-gradient(45deg, #1ec480, #14e4a0);
        }

        .bg-danger-gradient {
            background: linear-gradient(45deg, #f44336, #ff7043);
        }

        .status-icon-badge {
            width: 60px;
            height: 60px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        @media print {

            .btn,
            .carousel-control-prev,
            .carousel-control-next,
            .mini-thumbnail-grid {
                display: none !important;
            }

            .main-panel {
                margin-left: 0 !important;
            }
        }
    </style>
