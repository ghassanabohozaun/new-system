/*
 * Custom Dashboard Styles
 * All new custom styles for the dashboard should be added to this file
 * instead of being added inline to the layout file.
 */

/*
 * =============================================================================
 * THE RADICAL BULLETPROOF MODAL SYSTEM (Ultra-Wide, Pro-Scaling)
 * =============================================================================
 */

/* 1. Global Centering & Reset (Standard Bootstrap Logic) */
.modal .modal-dialog {
    margin: 1.75rem auto !important; /* Standard BS margin, forced */
    display: block !important; /* Ensure it's not flex which can shrink it */
}

/* Ensure centered modals stay centered horizontally */
.modal-dialog-centered {
    display: flex !important;
    align-items: center !important;
    min-height: calc(100% - 3.5rem) !important;
}

/* 2. DEFINITIVE POWER SCALING (Bulletproof Widths) */

/* [ULTRA-WIDE] - 1450px */
.modal .modal-dialog.modal-uw {
    width: 1450px !important;
    min-width: 1450px !important;
    max-width: 98% !important;
    --bs-modal-width: 1450px !important;
}

/* [LARGE] - 1100px */
.modal .modal-dialog.modal-lg,
.modal .modal-dialog.custom-modal-lg {
    width: 1100px !important;
    min-width: 1100px !important;
    max-width: 96% !important;
    --bs-modal-width: 1100px !important;
}

/* [MEDIUM] - 850px */
.modal .modal-dialog.modal-md,
.modal .modal-dialog.custom-modal-md {
    width: 850px !important;
    min-width: 850px !important;
    max-width: 94% !important;
    --bs-modal-width: 850px !important;
}

/* [SMALL] - 450px */
.modal .modal-dialog.modal-sm,
.modal .modal-dialog.custom-modal-sm {
    width: 450px !important;
    min-width: 450px !important;
    max-width: 92% !important;
    --bs-modal-width: 450px !important;
}

/* 3. RESPONSIVE ADAPTABILITY (Force scale-down on smaller screens) */
@media (max-width: 1500px) {
    .modal .modal-dialog.modal-uw {
        width: 96% !important;
        min-width: auto !important;
    }
}

@media (max-width: 1200px) {
    .modal .modal-dialog.modal-lg,
    .modal .modal-dialog.custom-modal-lg {
        width: 92% !important;
        min-width: auto !important;
    }
}

@media (max-width: 992px) {
    .modal .modal-dialog.modal-md,
    .modal .modal-dialog.custom-modal-md {
        width: 94% !important;
        min-width: auto !important;
        margin: 1.75rem auto !important;
    }
}

@media (max-width: 576px) {
    .modal .modal-dialog.modal-sm,
    .modal .modal-dialog.custom-modal-sm {
        width: 95% !important;
        min-width: auto !important;
        margin: 1.75rem auto !important;
    }

    .modal .modal-dialog {
        margin: 0.5rem !important; /* Tighter margins on mobile */
    }
}

/* 4. Support legacy class removal if found in scripts */
.modal-ml, .modal-xl { width: auto !important; }

.swal2-popup {
    font-size: 0.9rem !important;
}

.swal2-title {
    font-size: 1rem !important;
}

.swal2-html-container {
    font-size: 0.85rem !important;
}

.swal2-confirm,
.swal2-cancel {
    font-size: 0.85rem !important;
    padding: 8px 20px !important;
}

.table th,
.table td {
    padding: 0.5rem 0.9375rem !important;
}

.table th {
    font-size: 0.82rem !important;
    text-transform: uppercase;
    font-weight: 700;
    color: #444;
}

/* Shrink table column to fit its content (used for Actions column) */
.td-fit {
    width: 1% !important;
    white-space: nowrap !important;
}

/* Center content inside a td (for Status/Manage Status columns) */
.td-center-content {
    vertical-align: middle !important;
    text-align: center !important;
}

.td-center-content > * {
    display: inline-flex !important;
    justify-content: center !important;
    align-items: center !important;
