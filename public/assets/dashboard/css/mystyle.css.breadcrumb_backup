/* ============================================================
   DASHBOARD UI STANDARDIZATION — MEDIUM SIZE DESIGN SYSTEM
   Covers: Typography · Forms · Buttons · Tables · Sidebar
           Navbar · Modals · Cards · Responsive (all breakpoints)
   Works equally in LTR (English) and RTL (Arabic)
   ============================================================ */

/* — CSS Tokens (easy to tweak later) — */
:root {
    --dash-font-base:       0.8125rem;  /* 13px */
    --dash-font-sm:         0.75rem;    /* 12px */
    --dash-font-xs:         0.6875rem;  /* 11px */
    --dash-font-lg:         0.9375rem;  /* 15px */
    --dash-font-xl:         1.0625rem;  /* 17px */
    --dash-line-height:     1.5;
    --dash-radius:          6px;
    --dash-input-height:    34px;
    --dash-btn-height:      34px;
    --dash-cell-py:         0.4rem;
    --dash-cell-px:         0.8rem;
}

/* — Body — */
body {
    font-size: var(--dash-font-base) !important;
    line-height: var(--dash-line-height) !important;
}

/* — Page headings — */
.card-title {
    font-size: var(--dash-font-lg) !important;
    font-weight: 600 !important;
}
.card-description {
    font-size: var(--dash-font-sm) !important;
}

/* — Labels — */
label,
.form-label {
    font-size: var(--dash-font-base) !important;
    margin-bottom: 0.15rem !important;
}

/* — Form controls (standard) — */
.form-control,
.form-select {
    font-size: var(--dash-font-base) !important;
    min-height: var(--dash-input-height) !important;
    height: var(--dash-input-height) !important;
    padding: 0.3rem 0.75rem !important;
    border-radius: var(--dash-radius) !important;
    line-height: var(--dash-line-height) !important;
}

/* — Form controls (small) — */
.form-control-sm,
.form-select-sm {
    font-size: 0.875rem !important;
    min-height: 30px !important;
    padding: 0.2rem 0.6rem !important;
    border-radius: var(--dash-radius) !important;
}

/* — Textarea keeps auto height — */
textarea.form-control,
textarea.form-control-sm {
    min-height: unset !important;
    height: auto !important;
}

/* — Buttons (standard) — */
.btn {
    font-size: var(--dash-font-base) !important;
    min-height: var(--dash-btn-height) !important;
    padding: 0.3rem 0.95rem !important;
    border-radius: var(--dash-radius) !important;
    line-height: 1.4 !important;
}
.btn-sm {
    font-size: 0.875rem !important;
    min-height: var(--dash-input-height) !important;
    height: var(--dash-input-height) !important;
    padding: 0.2rem 0.65rem !important;
    border-radius: calc(var(--dash-radius) - 1px) !important;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
.btn-lg {
    font-size: var(--dash-font-lg) !important;
    min-height: 42px !important;
    padding: 0.5rem 1.3rem !important;
}

/* — Tables — */
.table {
    font-size: var(--dash-font-base) !important;
}
.table thead th,
.table > thead > tr > th {
    font-size: var(--dash-font-sm) !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.04em !important;
    padding: var(--dash-cell-py) var(--dash-cell-px) !important;
    vertical-align: middle !important;
    white-space: nowrap !important;
}
.table tbody td,
.table > tbody > tr > td {
    font-size: var(--dash-font-base) !important;
    padding: var(--dash-cell-py) var(--dash-cell-px) !important;
    vertical-align: middle !important;
}

/* DataTables pagination, info & length */
.dataTables_info,
.dataTables_length label,
.dataTables_length select,
.dataTables_filter label,
.dataTables_filter input {
    font-size: var(--dash-font-sm) !important;
}
.dataTables_wrapper .dataTables_paginate .paginate_button {
    font-size: var(--dash-font-sm) !important;
    padding: 0.2rem 0.55rem !important;
}

/* — Sidebar — */
.sidebar .nav .nav-item .nav-link {
    font-size: 0.875rem !important;
    padding: 0.68rem 1rem !important;
}
.sidebar .nav .nav-item .nav-link .menu-icon {
    font-size: 1.1rem !important;
    vertical-align: middle !important;
}
.sidebar .nav .nav-item .menu-title {
    font-size: 0.875rem !important;
    vertical-align: middle !important;
}
.sidebar .nav.sub-menu .nav-item .nav-link {
    font-size: 0.825rem !important;
    padding: 0.45rem 1rem !important;
}
.sidebar .nav-item.nav-category {
    font-size: 0.72rem !important;
    letter-spacing: 0.03em !important;
    font-weight: 700 !important;
    padding: 0.6rem 1rem 0.3rem !important;
    opacity: 0.6;
}

/* — Navbar — */
.navbar .navbar-menu-wrapper {
    font-size: var(--dash-font-base) !important;
}
.navbar .nav-item .nav-link {
    font-size: var(--dash-font-base) !important;
}
.navbar .dropdown-menu .dropdown-item {
    font-size: var(--dash-font-sm) !important;
    padding: 0.4rem 1rem !important;
}
.navbar .navbar-brand-wrapper .brand-logo,
.navbar .navbar-brand-wrapper .brand-logo-mini {
    width: auto !important;
}

/* — Breadcrumbs — */
.breadcrumb,
.breadcrumb-item,
.breadcrumb-item a {
    font-size: 0.82rem !important;
}

/* — Modal — */
.modal-title {
    font-size: var(--dash-font-lg) !important;
    font-weight: 600 !important;
}
.modal-body {
    font-size: var(--dash-font-base) !important;
}
.modal-footer .btn {
    font-size: 0.82rem !important;
}

/* — Badges & small — */
.badge {
    font-size: 0.72rem !important;
    padding: 0.28em 0.55em !important;
}
small, .small, .text-small {
    font-size: var(--dash-font-xs) !important;
}

/* — Input groups — */
.input-group-text {
    font-size: var(--dash-font-sm) !important;
    padding: 0.3rem 0.75rem !important;
}

/* =====================================================
   RESPONSIVE: Tablet (≤ 992px)
   ===================================================== */
@media (max-width: 992px) {
    :root {
        --dash-font-base:    0.85rem;
        --dash-font-sm:      0.78rem;
        --dash-font-xs:      0.72rem;
        --dash-input-height: 34px;
        --dash-btn-height:   34px;
        --dash-cell-py:      0.5rem;
        --dash-cell-px:      0.7rem;
    }
    .sidebar .nav .nav-item .nav-link {
        font-size: 0.85rem !important;
        padding: 0.6rem 0.85rem !important;
    }
    .card-title { font-size: 0.95rem !important; }
    .modal-title { font-size: 0.95rem !important; }
}

/* =====================================================
   RESPONSIVE: Mobile (≤ 576px)
   ===================================================== */
@media (max-width: 576px) {
    :root {
        --dash-font-base:    0.82rem;
        --dash-font-sm:      0.75rem;
        --dash-font-xs:      0.7rem;
        --dash-input-height: 32px;
        --dash-btn-height:   32px;
        --dash-cell-py:      0.4rem;
        --dash-cell-px:      0.55rem;
    }
    .btn { padding: 0.3rem 0.75rem !important; }
    .btn-sm { padding: 0.2rem 0.5rem !important; }
    .card-title { font-size: 0.9rem !important; }
    .modal-title { font-size: 0.9rem !important; }
    .table thead th { font-size: 0.72rem !important; }
    .table tbody td { font-size: 0.78rem !important; }
    .sidebar .nav .nav-item .nav-link {
        font-size: 0.82rem !important;
        padding: 0.5rem 0.75rem !important;
    }
    .navbar .nav-item .nav-link { font-size: 0.82rem !important; }
    label, .form-label { font-size: 0.82rem !important; }
}

/* ===== Floating Command HUD (Premium) ===== */
.command-hud-wrapper {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    z-index: 1100;
    opacity: 0;
    visibility: hidden;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.command-hud-wrapper.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    visibility: visible;
}

.hud-capsule {
    background: rgba(26, 29, 46, 0.85);
    backdrop-filter: blur(15px) saturate(180%);
    -webkit-backdrop-filter: blur(15px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    padding: 10px 10px 10px 24px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4), inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    min-width: fit-content;
    display: flex;
    align-items: center;
    gap: 20px;
}

.hud-status-section {
    display: flex;
    align-items: center;
    gap: 15px;
    padding-right: 20px;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
}

.hud-pulse-orb {
    width: 10px;
    height: 10px;
    background: #4b49ac;
    border-radius: 50%;
    position: relative;
    box-shadow: 0 0 8px #4b49ac;
}

.hud-pulse-orb::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 50%;
    background: #4b49ac;
    animation: orbPulse 2s infinite;
}

@keyframes orbPulse {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(3); opacity: 0; }
}

/* Error State for HUD Orb */
.hud-pulse-orb.has-errors {
    background: #ff4747;
    box-shadow: 0 0 12px #ff4747;
}

.hud-pulse-orb.has-errors::after {
    background: #ff4747;
    animation: orbPulseRed 1.5s infinite;
}

@keyframes orbPulseRed {
    0% { transform: scale(1); opacity: 0.9; }
    100% { transform: scale(3.5); opacity: 0; }
}

.hud-count-text {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.3px;
}

.hud-hint-text {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.7rem;
    margin-top: 1px;
}

.hud-actions-section {
    display: flex;
    align-items: center;
    gap: 12px;
}

.btn-hud-primary,
.btn-hud-secondary {
    border-radius: 100px;
    height: 44px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 24px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
    text-decoration: none;
}

.btn-hud-primary {
    background: #fff;
    color: #1a1d2e;
    box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);
}

.btn-hud-primary:hover {
    background: #e9ecef;
    transform: scale(1.03);
}

.btn-hud-secondary {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 0 18px;
}

.btn-hud-secondary:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
}

.btn-hud-primary .btn-label,
.btn-hud-secondary .btn-label {
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    white-space: nowrap;
    display: inline-block;
    vertical-align: middle;
    transition: max-width 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s ease, margin 0.3s ease;
    will-change: max-width, opacity;
    margin-left: 0;
}

.hud-capsule:hover .btn-label {
    max-width: 150px;
    opacity: 1;
    margin-left: 8px;
}

