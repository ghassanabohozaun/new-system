/* Profile Page Specific Styles */
.profile-page-wrapper {
    font-size: calc(1rem - 2px);
}


.profile-page-wrapper p,
.profile-page-wrapper span,
.profile-page-wrapper a,
.profile-page-wrapper label,
.profile-page-wrapper .badge {
    font-size: calc(100% - 2px);
}

.profile-page-wrapper h3 {
    font-size: calc(1.75rem - 2px);
}

.profile-page-wrapper h5 {
    font-size: calc(1.25rem - 2px);
}

.profile-page-wrapper h6 {
    font-size: calc(1rem - 2px);
}

/* Flag and Phone Code Display */
.flag-box {
    display: inline-flex;
    align-items: center;
    background: #ffffff;
    border-radius: 50px;
    padding: 3px 10px;
    border: 1px solid #e0e0e0;
    transition: all 0.2s ease-in-out;
    cursor: default;
    min-width: 80px;
    justify-content: center;
}

.flag-box:hover {
    border-color: #1F3BB3;
    background-color: #f0f3ff;
}

.flag-box .flag-icon {
    border-radius: 2px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
}

.flag-box .code-text {
