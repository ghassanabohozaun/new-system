}

/* RTL/LTR table alignment fix: force text-start to respect page direction */
[dir="ltr"] .table .text-start,
[dir="ltr"] .table th.text-start {
    text-align: left !important;
}

[dir="rtl"] .table .text-start,
[dir="rtl"] .table th.text-start {
    text-align: right !important;
}

.breadcrumb {
    font-size: 12px !important;
}

.card-title {
    font-size: 0.88rem !important;
    font-weight: 700;
}

/* Todo List Styles */
.todo-list-input {
    flex-grow: 1;
    margin-right: 1.125rem;
}

.list-wrapper {
    max-height: 450px;
    overflow-y: auto;
}

.todo-list li .form-check {
    margin-top: 0;
    margin-bottom: 0;
}

.todo-list li.completed label {
    text-decoration: line-through;
    color: #9c9fa6;
}

/* Validation Error Styles */
.is-invalid,
.form-control.is-invalid,
.form-select.is-invalid {
    border: 1px solid #F64E60 !important;
    border-color: #F64E60 !important;
}

/* Propagate invalid border to input-group components */
.input-group:has(.is-invalid) .input-group-text,
.input-group:has(.is-invalid) .form-control,
.input-group-premium.is-invalid {
    border-color: #F64E60 !important;
}

.input-group-premium.is-invalid .input-group-text {
    border-right: 1px solid #F64E60 !important;
}

[dir="rtl"] .input-group-premium.is-invalid .input-group-text {
    border-right: none !important;
    border-left: 1px solid #F64E60 !important;
}

/* Summernote Validation Styling */
textarea.is-invalid + .note-editor {
    border-color: #F64E60 !important;
}

textarea.is-invalid + .note-editor .note-toolbar {
    border-bottom: 1px solid #F64E60 !important;
}

/* RTL Specific: Move icon to left and adjust padding */
.rtl .is-invalid,
.rtl .form-control.is-invalid {
    background-position: left calc(0.375em + 0.1875rem) center !important;
    padding-left: calc(0.75em + 1.25rem) !important;
    padding-right: 0.5rem !important;
}

/* Handle form-select separately to avoid chevron collision (RTL) */
.rtl .form-select.is-invalid {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e"), url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23F64E60'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23F64E60' stroke='none'/%3e%3c/svg%3e") !important;
    background-position: left 0.75rem center, left 2.25rem center !important;
    background-size: 16px 12px, calc(0.75em + 0.375rem) calc(0.75em + 0.375rem) !important;
    background-repeat: no-repeat !important;
    padding-left: 3.5rem !important;
    padding-right: 0.5rem !important;
}

/* Ensure the red exclamation icon appears for LTR .form-select.is-invalid */
[dir="ltr"] .form-select.is-invalid {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e"), url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23F64E60'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23F64E60' stroke='none'/%3e%3c/svg%3e") !important;
    background-position: right 0.75rem center, center right 2.25rem !important;
    background-size: 16px 12px, calc(0.75em + 0.375rem) calc(0.75em + 0.375rem) !important;
    background-repeat: no-repeat !important;
    padding-right: 4.125rem !important;
}

/* Select2 Validation Styling */
.is-invalid + .select2-container--default .select2-selection--single,
.input-group-premium.is-invalid .select2-container--default .select2-selection--single {
    border-color: #F64E60 !important;
}

/* Ensure no double border when select2 is in premium group */
.input-group-premium .select2-container--default .select2-selection--single {
    border: none !important;
}

[dir="ltr"] .is-invalid + .select2-container--default .select2-selection--single,
[dir="ltr"] .input-group-premium.is-invalid .select2-container--default .select2-selection--single {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23F64E60'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23F64E60' stroke='none'/%3e%3c/svg%3e") !important;
    background-position: center right 2.25rem !important;
    background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem) !important;
    background-repeat: no-repeat !important;
    padding-right: 3.5rem !important;
}

[dir="rtl"] .is-invalid + .select2-container--default .select2-selection--single,
[dir="rtl"] .input-group-premium.is-invalid .select2-container--default .select2-selection--single {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23F64E60'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23F64E60' stroke='none'/%3e%3c/svg%3e") !important;
    background-position: center left 2.25rem !important;
    background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem) !important;
    background-repeat: no-repeat !important;
    padding-left: 3.5rem !important;
}

.is-invalid + .select2-container--default.select2-container--focus .select2-selection--single {
    border-color: #F64E60 !important;
    box-shadow: 0 0 0 0.2rem rgba(246, 78, 96, 0.25) !important;
