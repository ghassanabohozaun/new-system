/*
 * =============================================================================
 * LUXURY BREADCRUMB TRANSFORMATION (High-End UI)
 * =============================================================================
 */

/* 1. The Glass Container */
nav[aria-label="breadcrumb"] {
    background: rgba(255, 255, 255, 0.45) !important;
    backdrop-filter: blur(12px) !important;
    -webkit-backdrop-filter: blur(12px) !important;
    border: 1px solid rgba(255, 255, 255, 0.5) !important;
    border-radius: 12px !important;
    padding: 2px 15px !important;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03) !important;
    display: inline-flex !important;
    align-items: center !important;
}

.breadcrumb {
    background: transparent !important;
    margin-bottom: 0 !important;
    padding: 0.5rem 0 !important;
}

/* 2. Breadcrumb Items & Dividers */
.breadcrumb-item {
    display: flex !important;
    align-items: center !important;
    font-weight: 400 !important;
    font-size: 0.85rem !important;
    color: #64748b !important; /* Neutral Slate */
}

/* Home Icon Addition */
.breadcrumb-item:first-child::before {
    content: "\e800"; /* Using Feather icon code if available, or fallback */
    font-family: 'feather';
    margin-right: 8px;
    font-size: 0.9rem;
    color: #1F3BB3;
    opacity: 0.8;
}

.rtl .breadcrumb-item:first-child::before {
    margin-right: 0;
    margin-left: 8px;
}

/* Custom Divider (Modern Angle) */
.breadcrumb-item + .breadcrumb-item::before {
    content: "\F035C"; /* MDI chevron-right or similar */
    font-family: "Material Design Icons";
    padding: 0 12px !important;
    color: rgba(31, 59, 179, 0.2) !important;
    font-size: 1rem !important;
}

.rtl .breadcrumb-item + .breadcrumb-item::before {
    transform: rotate(180deg);
}

/* 3. Link Style & Magnetic Hover */
.breadcrumb-item a {
    color: #475569 !important;
    text-decoration: none !important;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    display: inline-block !important;
}

.breadcrumb-item a:hover {
    color: #1F3BB3 !important;
    transform: translateY(-1px);
    text-shadow: 0 0 10px rgba(31, 59, 179, 0.2);
}

/* 4. Active State (Luxury Capsule) */
.breadcrumb-item.active {
    color: #1F3BB3 !important;
    font-weight: 600 !important;
    background: rgba(31, 59, 179, 0.08) !important;
    padding: 4px 14px !important;
    border-radius: 8px !important;
}

/* 5. Responsive Adaptability */
@media screen and (max-width: 575px) {
    nav[aria-label="breadcrumb"] {
        max-width: 100%;
        overflow-x: auto;
        white-space: nowrap;
        scrollbar-width: none; /* Hide scrollbar Firefox */
    }
    nav[aria-label="breadcrumb"]::-webkit-scrollbar {
        display: none; /* Hide scrollbar Chrome/Safari */
    }

    .breadcrumb-item:not(.active):not(:first-child) span,
    .breadcrumb-item:not(.active):not(:first-child) a {
        max-width: 60px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: inline-block;
        vertical-align: middle;
    }
}

/* Staggered Loading Animation */
@keyframes breadcrumbSlide {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
}

.rtl @keyframes breadcrumbSlide {
    from { opacity: 0; transform: translateX(10px); }
    to { opacity: 1; transform: translateX(0); }
}

.breadcrumb-item {
    animation: breadcrumbSlide 0.5s ease forwards;
    opacity: 0;
}

.breadcrumb-item:nth-child(1) { animation-delay: 0.1s; }
.breadcrumb-item:nth-child(2) { animation-delay: 0.2s; }
.breadcrumb-item:nth-child(3) { animation-delay: 0.3s; }

/*
 * =============================================================================
 * PREMIUM INTEGRATED SIDEBAR (Luxury Upgrade - Integrated)
 * =============================================================================
 */

/* 1. Global Micro-Interactions (Integrated) */
.sidebar .nav .nav-item .nav-link {
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1) !important;
    position: relative;
    overflow: hidden;
}

/* Luxury Hover: Soft Scale & Glass Texture */
.sidebar .nav .nav-item:not(.active) > .nav-link:hover {
    background: rgba(255, 255, 255, 0.7) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transform: translateX(4px); /* Professional slide */
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
}

.rtl .sidebar .nav .nav-item:not(.active) > .nav-link:hover {
    transform: translateX(-4px);
}

/* 2. Active State: Sophisticated Gradient Indicator */
.sidebar .nav .nav-item.active > .nav-link {
    background: #fff !important;
    box-shadow: 0 4px 20px rgba(31, 59, 179, 0.08); /* Soft glow */
}

/* Dynamic Edge Indicator (LTR) */
.sidebar .nav .nav-item.active > .nav-link::before {
    content: "";
    position: absolute;
    left: 0;
    top: 20%;
    height: 60%;
    width: 4px;
    background: linear-gradient(to bottom, #1F3BB3, #4B49AC);
    border-radius: 0 4px 4px 0;
    transition: all 0.3s ease;
}

/* Dynamic Edge Indicator (RTL) */
.rtl .sidebar .nav .nav-item.active > .nav-link::before {
    left: auto;
    right: 0;
    border-radius: 4px 0 0 4px;
}

/* 3. Sub-menu Staggered Bloom */
@keyframes navItemBloom {
    from {
        opacity: 0;
        transform: translateY(8px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.sidebar .nav.sub-menu .nav-item {
    animation: navItemBloom 0.45s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    opacity: 0;
}

/* Elegant Sequence Delays */
.sidebar .nav.sub-menu .nav-item:nth-child(1) { animation-delay: 0.04s; }
.sidebar .nav.sub-menu .nav-item:nth-child(2) { animation-delay: 0.08s; }
.sidebar .nav.sub-menu .nav-item:nth-child(3) { animation-delay: 0.12s; }
.sidebar .nav.sub-menu .nav-item:nth-child(4) { animation-delay: 0.16s; }
.sidebar .nav.sub-menu .nav-item:nth-child(5) { animation-delay: 0.20s; }

/* 4. Iconography & Arrow Micro-Motion */
.sidebar .nav .nav-item .nav-link .menu-icon {
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.2);
}

.sidebar .nav .nav-item .nav-link:hover .menu-icon {
    transform: scale(1.18) rotate(3deg);
    color: #1F3BB3 !important;
}

.sidebar .nav .nav-item.active .nav-link .menu-icon {
    filter: drop-shadow(0 2px 6px rgba(31, 59, 179, 0.25));
}

